# ================================================================
# CONFIGURACIÓN DE LA PLATAFORMA SAAS ELEGANCE NAILS
# Variables de entorno para desarrollo y producción
# ================================================================

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=elegance_nails_saas
MYSQL_PORT=3306

# File Upload Configuration
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# Email Configuration (para notificaciones)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@elegancenails.com

# External APIs
# Geocoding (usa Nominatim gratuito por defecto)
GEOCODING_API_KEY=optional-if-using-paid-service
GEOCODING_SERVICE=nominatim  # nominatim, google, mapbox

# Payment Gateway (para suscripciones premium)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Security
BCRYPT_LOG_ROUNDS=12
JWT_SECRET_KEY=your-jwt-secret-key

# Session Configuration
PERMANENT_SESSION_LIFETIME=86400  # 24 hours
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# File Storage (para logos y archivos)
# Local storage por defecto, cambiar a S3/Azure en producción
STORAGE_TYPE=local  # local, s3, azure
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BUCKET_NAME=your-s3-bucket
AWS_REGION=us-east-1

# Cache Configuration (Redis para producción)
CACHE_TYPE=simple  # simple, redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Business Map Configuration
DEFAULT_MAP_CENTER_LAT=40.4168
DEFAULT_MAP_CENTER_LNG=-3.7038  # Madrid, España
DEFAULT_MAP_ZOOM=6

# Subscription Limits (defaults)
FREE_PLAN_EMPLOYEES=3
FREE_PLAN_SERVICES=10
FREE_PLAN_APPOINTMENTS=50
FREE_PLAN_STORAGE_MB=100

PREMIUM_PLAN_EMPLOYEES=20
PREMIUM_PLAN_SERVICES=100
PREMIUM_PLAN_APPOINTMENTS=1000
PREMIUM_PLAN_STORAGE_MB=5000

# Trial Configuration
DEFAULT_TRIAL_DAYS=30
TRIAL_PLAN_ID=1  # ID del plan gratuito

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_PUSH_NOTIFICATIONS=False

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
ENABLE_ANALYTICS=False

# Social Login (opcional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://

# Backup Configuration
BACKUP_ENABLED=False
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_RETENTION_DAYS=30

# Development/Testing
TESTING=False
WTF_CSRF_ENABLED=True
PRESERVE_CONTEXT_ON_EXCEPTION=False

# Celery (para tareas en background)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API Rate Limits
API_RATE_LIMIT=1000 per hour
MAP_API_RATE_LIMIT=5000 per hour

# Feature Flags
ENABLE_BUSINESS_REVIEWS=True
ENABLE_LOYALTY_PROGRAM=True
ENABLE_ONLINE_PAYMENTS=True
ENABLE_APPOINTMENT_REMINDERS=True
ENABLE_WAITLIST=True

# Maintenance Mode
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=Plataforma en mantenimiento. Volveremos pronto.

# Admin Configuration
SUPER_ADMIN_EMAIL=admin@elegancenails.com
SUPER_ADMIN_PASSWORD=change-this-in-production

# Localization
DEFAULT_LANGUAGE=es
SUPPORTED_LANGUAGES=es,en
DEFAULT_TIMEZONE=Europe/Madrid
DEFAULT_CURRENCY=EUR
